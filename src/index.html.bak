<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Nova — Your Learning AI</title>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&display=swap" rel="stylesheet">
<style>
  :root{
    --bg:#0E1420; --panel:#18202E; --panel2:#202B3C; --line:#2A3648;
    --text:#E8EEF5; --muted:#8A97A8;
    --accent:#4FD8EB; --glow:14px;
  }
  *{box-sizing:border-box; margin:0; padding:0;}
  html,body{height:100%;}
  body{
    background:var(--bg); color:var(--text);
    font-family:'Space Grotesk',system-ui,sans-serif;
    display:flex; flex-direction:column; height:100dvh; overflow:hidden;
  }
  .mono{font-family:ui-monospace,'SF Mono',Menlo,monospace;}

  header{display:flex; align-items:center; gap:12px; padding:12px 16px; border-bottom:1px solid var(--line);}
  #orb{
    width:48px; height:48px; border-radius:50%; flex:none;
    display:flex; align-items:center; justify-content:center; font-size:26px;
    background:radial-gradient(circle at 35% 30%, var(--panel2), var(--bg));
    box-shadow:0 0 var(--glow) 2px color-mix(in srgb, var(--accent) 55%, transparent),
               inset 0 0 8px color-mix(in srgb, var(--accent) 35%, transparent);
    transition:box-shadow .4s;
  }
  #orb.thinking{animation:pulse 1s infinite;}
  @keyframes pulse{50%{box-shadow:0 0 calc(var(--glow) * 2) 6px color-mix(in srgb, var(--accent) 80%, transparent);}}
  @media (prefers-reduced-motion: reduce){ #orb.thinking{animation:none;} }
  .head-info{flex:1; min-width:0;}
  .head-info h1{font-size:17px; font-weight:700; letter-spacing:.3px;}
  .chips{display:flex; gap:6px; margin-top:3px; flex-wrap:wrap;}
  .chip{font-size:11px; color:var(--muted); background:var(--panel); border:1px solid var(--line); border-radius:99px; padding:2px 8px;}
  .chip b{color:var(--accent); font-weight:500;}
  #voicebtn{background:var(--panel); border:1px solid var(--line); border-radius:50%; width:38px; height:38px; font-size:17px; cursor:pointer; flex:none;}
  #voicebtn.on{border-color:var(--accent); box-shadow:0 0 8px color-mix(in srgb, var(--accent) 50%, transparent);}
  #voicebtn:focus-visible{outline:2px solid var(--accent);}

  nav{display:flex; border-bottom:1px solid var(--line);}
  nav button{flex:1; padding:10px 1px; background:none; border:none; cursor:pointer; color:var(--muted); font:inherit; font-size:11px; border-bottom:2px solid transparent;}
  nav button.active{color:var(--accent); border-bottom-color:var(--accent);}
  nav button:focus-visible{outline:2px solid var(--accent); outline-offset:-2px;}

  main{flex:1; overflow:hidden; display:flex; flex-direction:column;}
  .tab{display:none; flex:1; overflow-y:auto; flex-direction:column;}
  .tab.active{display:flex;}

  #chatlog{flex:1; overflow-y:auto; padding:16px; display:flex; flex-direction:column; gap:10px;}
  .bubble{max-width:82%; padding:9px 13px; border-radius:16px; line-height:1.45; font-size:15px; white-space:pre-wrap;}
  .exptag{font-size:10px; color:var(--muted); letter-spacing:.5px; margin-bottom:4px; text-transform:uppercase;}
  .bot{align-self:flex-start; background:var(--panel2); border-bottom-left-radius:4px;}
  .user{align-self:flex-end; background:color-mix(in srgb, var(--accent) 22%, var(--panel)); border-bottom-right-radius:4px;}
  .sys{align-self:center; color:var(--muted); font-size:12px; text-align:center;}
  #teachbar{display:none; padding:6px 16px; font-size:12px; color:var(--bg); background:var(--accent); font-weight:500;}
  #inputbar{display:flex; gap:6px; padding:10px 12px; border-top:1px solid var(--line);}
  #msg{flex:1; min-width:0; background:var(--panel); border:1px solid var(--line); border-radius:22px; padding:11px 16px; color:var(--text); font:inherit; font-size:15px;}
  #msg:focus{outline:2px solid var(--accent); border-color:transparent;}
  .roundbtn{background:var(--panel); color:var(--text); border:1px solid var(--line); border-radius:22px; padding:0 13px; font:inherit; cursor:pointer; font-size:16px;}
  .roundbtn.listening{border-color:#FF5A5A; box-shadow:0 0 10px #FF5A5A66;}
  #send{background:var(--accent); color:var(--bg); border:none; border-radius:22px; padding:0 18px; font:inherit; font-weight:700; cursor:pointer;}

  .panel-pad{padding:16px; display:flex; flex-direction:column; gap:14px;}
  h2{font-size:14px; text-transform:uppercase; letter-spacing:1.5px; color:var(--muted); font-weight:500;}
  label{font-size:13px; color:var(--muted); display:block; margin-bottom:4px;}
  input[type=text], select, textarea{width:100%; background:var(--panel); border:1px solid var(--line); border-radius:10px; padding:10px 12px; color:var(--text); font:inherit; font-size:14px;}
  textarea{resize:vertical; min-height:70px;}
  input:focus-visible, select:focus-visible, textarea:focus-visible{outline:2px solid var(--accent);}
  .btn{background:var(--accent); color:var(--bg); border:none; border-radius:10px; padding:10px 16px; font:inherit; font-weight:700; cursor:pointer; font-size:14px;}
  .btn.ghost{background:var(--panel); color:var(--text); border:1px solid var(--line); font-weight:500;}
  .btn.danger{background:#B33; color:#fff;}
  .btn:focus-visible{outline:2px solid var(--text);}
  .row{display:flex; gap:8px;}
  .row > *{flex:1;}

  .topic-item{display:flex; align-items:center; gap:10px; padding:12px; background:var(--panel); border:1px solid var(--line); border-radius:12px; cursor:pointer;}
  .topic-item.selected{border-color:var(--accent);}
  .topic-item .t-name{flex:1; font-weight:500;}
  .topic-item .t-count{font-size:12px; color:var(--muted);}
  .topic-item .t-del{background:none; border:none; color:var(--muted); cursor:pointer; font-size:16px; padding:4px;}

  .p-card{display:flex; align-items:center; gap:12px; padding:12px; background:var(--panel); border:1px solid var(--line); border-radius:12px; cursor:pointer;}
  .p-card.selected{border-color:var(--accent); background:var(--panel2);}
  .p-face{font-size:26px;}
  .p-name{font-weight:700;}
  .p-desc{font-size:12px; color:var(--muted);}
  .note{font-size:12px; color:var(--muted); line-height:1.5;}

  #memcanvas{
    width:100%; flex:1; min-height:320px; touch-action:none;
    background:radial-gradient(circle at 50% 40%, var(--panel) 0%, var(--bg) 75%);
    border:1px solid var(--line); border-radius:14px;
  }

  #quizcard{background:var(--panel); border:1px solid var(--line); border-radius:14px; padding:16px; display:flex; flex-direction:column; gap:12px;}
  #quiz-q{font-size:17px; font-weight:500; line-height:1.4;}
  #quiz-feedback{font-size:14px; line-height:1.5;}
  .scoreline{display:flex; gap:6px; flex-wrap:wrap;}
</style>
</head>
<body>

<header>
  <div id="orb">🙂</div>
  <div class="head-info">
    <h1 id="botname">Nova</h1>
    <div class="chips mono">
      <span class="chip">⭐ <b id="c-level">Lv 1</b></span>
      <span class="chip"><b id="c-mood">🤔 curious</b></span>
      <span class="chip">🧠 <b id="c-facts">0</b></span>
      <span class="chip">📖 <b id="c-words">0</b></span>
      <span class="chip">session <b id="c-session">1</b></span>
    </div>
  </div>
  <button id="voicebtn" aria-label="Toggle Nova's voice">🔇</button>
</header>

<nav>
  <button class="active" data-tab="chat">💬 Chat</button>
  <button data-tab="teach">📚 Teach</button>
  <button data-tab="quiz">🎓 Quiz</button>
  <button data-tab="memories">🕸️ Memory</button>
  <button data-tab="net">🧠 Net</button>
  <button data-tab="train">🎯 Train</button>
  <button data-tab="topics">📂 Topics</button>
  <button data-tab="persona">🎭 Style</button>
</nav>

<main>
  <!-- CHAT -->
  <section id="tab-chat" class="tab active">
    <div id="teachbar"></div>
    <div id="chatlog"></div>
    <div id="inputbar">
      <input id="msg" type="text" placeholder="Say something…" autocomplete="off">
      <button id="micbtn" class="roundbtn" aria-label="Talk to Nova" style="display:none">🎤</button>
      <button id="imaginebtn" class="roundbtn" aria-label="Imagine a sentence">✨</button>
      <button id="send">Send</button>
    </div>
  </section>

  <!-- TEACH -->
  <section id="tab-teach" class="tab">
    <div class="panel-pad">
      <h2>Teach one fact</h2>
      <div id="teach-dest" class="note" style="color:var(--accent); font-weight:600;">→ Teaching into: 'general'</div>
      <div>
        <label for="t-topic">Topic</label>
        <div class="row">
          <select id="t-topic"></select>
          <input id="t-newtopic" type="text" placeholder="…or new topic name">
        </div>
      </div>
      <div><label for="t-q">Question</label><input id="t-q" type="text" placeholder="what is mars"></div>
      <div><label for="t-a">Answer</label><input id="t-a" type="text" placeholder="Mars is the red planet"></div>
      <button class="btn" id="t-add">Teach it</button>

      <h2 style="margin-top:10px">🌐 Study from the internet</h2>
      <p class="note">Nova reads only credible, openly-licensed sources: the Wikimedia library (encyclopedias, how-to manuals, courses, travel guides) and Stack Exchange (expert answers ranked by community votes). Pick a subject, a source, and a size.</p>
      <div><label for="w-subject">Subject</label><input id="w-subject" type="text" placeholder="Saturn, dinosaurs, Minecraft…"></div>
      <div><label for="w-topic">Save into topic</label><input id="w-topic" type="text" placeholder="space (created if new)"></div>
      <div>
        <label for="w-source">Where to read from (all credible sources)</label>
        <select id="w-source">
          <option value="mix">🌍 Everything credible (mix)</option>
          <option value="wikipedia">📕 Wikipedia — encyclopedia facts</option>
          <option value="simple">🧒 Simple Wikipedia — plain explanations</option>
          <option value="wikibooks">📘 Wikibooks — how-to manuals</option>
          <option value="wikiversity">🎓 Wikiversity — courses & lessons</option>
          <option value="wikivoyage">🗺️ Wikivoyage — travel guides</option>
          <option value="wiktionary">📖 Wiktionary — word definitions & etymology</option>
          <option value="arxiv">📄 arXiv — real academic paper abstracts</option>
          <option value="openlibrary">📚 Open Library — real book descriptions</option>
          <option value="howto">🛠️ Stack Exchange — expert how-to Q&A</option>
        </select>
      </div>
      <div>
        <label for="w-size">How much to read</label>
        <select id="w-size">
          <option value="20">Standard — ~20 facts</option>
          <option value="100">Big dump — ~100 facts</option>
          <option value="300">MEGA dump — ~300 facts 📦</option>
          <option value="1000">GIGA dump — ~1000 facts 🌋</option>
        </select>
      </div>
      <button class="btn" id="w-study">Study</button>

      <h2 style="margin-top:10px">Bulk teach</h2>
      <p class="note">Paste many facts at once — one per line:<br><span class="mono">what is mars | Mars is the red planet</span></p>
      <textarea id="t-bulk" placeholder="question | answer&#10;question | answer"></textarea>
      <button class="btn ghost" id="t-bulkadd">Add all lines</button>
      <div class="note" id="t-status"></div>
    </div>
  </section>

  <!-- QUIZ -->
  <section id="tab-quiz" class="tab">
    <div class="panel-pad">
      <h2>🎓 Nova quizzes you</h2>
      <p class="note">Nova asks from its current chat scope (change it in 📂 Topics). Correct answers earn you +10 XP for Nova.</p>
      <div id="quizcard">
        <div id="quiz-q">Tap "New question" to start!</div>
        <input id="quiz-a" type="text" placeholder="Your answer…">
        <div class="row">
          <button class="btn" id="quiz-submit">Answer</button>
          <button class="btn ghost" id="quiz-next">New question</button>
        </div>
        <div id="quiz-feedback"></div>
      </div>
      <div class="scoreline mono">
        <span class="chip">score <b id="q-score">0/0</b></span>
        <span class="chip">streak <b id="q-streak">0</b></span>
        <span class="chip">best streak <b id="q-best">0</b></span>
      </div>
    </div>
  </section>

  <!-- MEMORIES -->
  <section id="tab-memories" class="tab">
    <div class="panel-pad" style="flex:1; min-height:0;">
      <h2>🕸️ Nova's mind — every memory, connected</h2>
      <p class="note">Colored hubs are topics; dots are memories in their topic's color. Pinch or scroll to zoom, drag space to pan, drag dots to rearrange, double-tap to reset. On big brains, idea-links stay hidden until you tap a memory or zoom in close — otherwise hundreds of threads turn into a hairball.</p>
      <input id="memsearch" type="text" placeholder="🔎 Search Nova's memories…">
      <canvas id="memcanvas"></canvas>
      <div id="memdetail" class="note" style="display:none; background:var(--panel); border:1px solid var(--line); border-radius:12px; padding:12px;"><span></span> <button id="memforget" class="btn danger" style="display:none; padding:6px 10px; font-size:12px; margin-top:6px;">Forget this memory</button></div>
    </div>
  </section>

  <!-- NEURAL NET -->
  <section id="tab-net" class="tab">
    <div class="panel-pad" style="flex:1; min-height:0;">
      <h2>🧠 Nova's neural network — live</h2>
      <p class="note" id="net-info">Waiting for the network to train…</p>
      <div class="row">
        <select id="net-size">
          <option value="auto">🌱 Auto — grows with the brain</option>
          <option value="large">💪 Large — ~1.2 million parameters</option>
          <option value="max">🔥 MAXIMUM — ~4.7 million parameters</option>
        </select>
      </div>
      <input id="net-probe" type="text" placeholder="Type a question and watch the thought flow →">
      <canvas id="netcanvas" style="width:100%; flex:1; min-height:300px; background:radial-gradient(circle at 50% 40%, var(--panel) 0%, var(--bg) 75%); border:1px solid var(--line); border-radius:14px;"></canvas>
      <p class="note">Left → right: your words → hidden layer 1 → hidden layer 2 → topic verdict. Teal links push a signal up, pink links push it down; brighter neurons are firing harder. This is the real network — every line is a real learned weight.</p>

      <div id="native-net-section" style="display:none; margin-top:18px; padding-top:18px; border-top:1px solid var(--line); display:flex; flex-direction:column; gap:10px;">
        <h2>🚀 Native network (desktop app only)</h2>
        <p class="note">This app is running as a desktop app, so Nova can also train a MUCH bigger network in compiled Rust instead of JavaScript — the browser version never had this option. This is a separate, optional model from the one above; it doesn't change how Nova routes chat messages, it's just a real, much larger network you can train and inspect.</p>
        <select id="native-net-size">
          <option value="standard">🌱 Standard — ~1.2 million parameters</option>
          <option value="large">💪 Large — ~4.7 million parameters</option>
          <option value="ultra">🚀 Ultra — ~19 million parameters (can take a few minutes to train)</option>
        </select>
        <button class="btn" id="native-net-train">Train native network</button>
        <p class="note" id="native-net-status">Not trained yet.</p>

        <h2 style="margin-top:14px">🧠 Native generator — actual neural text/code</h2>
        <p class="note">This trains a SECOND native network — one that predicts "what word comes next," the same core idea behind large language models. It generates genuinely original sentences by repeatedly predicting the next word, rather than reciting stored text or gluing random words together. Honest limit: it's small, so it won't reliably write syntactically correct code — Nova's regular 💻 Code builder stays the reliable path for that. This is the creative, experimental one.</p>
        <select id="native-gen-size">
          <option value="standard">🌱 Standard — ~600 word vocabulary</option>
          <option value="large">💪 Large — ~1200 word vocabulary</option>
          <option value="ultra">🚀 Ultra — ~2500 word vocabulary</option>
        </select>
        <button class="btn" id="native-gen-train">Train native generator</button>
        <div class="row">
          <input id="native-gen-seed" type="text" placeholder="Optional seed word…">
          <button class="btn ghost" id="native-gen-run">Generate</button>
        </div>
        <p class="note" id="native-gen-status">Not trained yet.</p>

        <h2 style="margin-top:14px">🧬 Native embeddings — real semantic understanding</h2>
        <p class="note">This trains a third native network: real word embeddings (the same core idea as word2vec). Once trained, Nova can tell that words like "car" and "automobile" are related — matching by MEANING, not just shared letters. Try "Nearest words" on something Nova has read a lot about.</p>
        <select id="native-embed-size">
          <option value="standard">🌱 Standard — 32 dimensions</option>
          <option value="large">💪 Large — 64 dimensions</option>
          <option value="ultra">🚀 Ultra — 96 dimensions</option>
        </select>
        <button class="btn" id="native-embed-train">Train native embeddings</button>
        <div class="row">
          <input id="native-embed-word" type="text" placeholder="A word Nova has read…">
          <button class="btn ghost" id="native-embed-nearest">Nearest words</button>
        </div>
        <p class="note" id="native-embed-status">Not trained yet.</p>
      </div>
    </div>
  </section>

  <!-- TRAIN -->
  <section id="tab-train" class="tab">
    <div class="panel-pad">
      <h2>🎯 Pick an agent to train directly</h2>
      <p class="note">Assign topics to an agent so it — and only it — answers from them. Feed it single facts, bulk pastes, or a Deep Study, all scoped to this agent.</p>
      <div id="train-agentlist"></div>

      <div id="train-panel" style="display:none; flex-direction:column; gap:14px;">
        <h2 id="train-heading" style="margin-top:6px">Training: —</h2>
        <div class="note" id="train-stats"></div>

        <label>Topics owned by this agent</label>
        <div id="train-topiclist"></div>
        <div class="row">
          <select id="train-existing"></select>
          <button class="btn ghost" id="train-assign">Assign</button>
        </div>
        <div class="row">
          <input id="train-newtopic" type="text" placeholder="…or create + assign a new topic">
          <button class="btn ghost" id="train-createassign">Create</button>
        </div>

        <h2 style="margin-top:6px">Teach one fact</h2>
        <div><label for="tr-q">Question</label><input id="tr-q" type="text" placeholder="what is a for loop"></div>
        <div><label for="tr-a">Answer</label><input id="tr-a" type="text" placeholder="Repeats code for each item"></div>
        <button class="btn" id="tr-add">Teach it</button>

        <h2 style="margin-top:6px">Bulk teach</h2>
        <textarea id="tr-bulk" placeholder="question | answer&#10;question | answer"></textarea>
        <button class="btn ghost" id="tr-bulkadd">Add all lines</button>

        <h2 style="margin-top:6px">🌐 Deep Study directly into this agent</h2>
        <div><label for="tr-subject">Subject</label><input id="tr-subject" type="text" placeholder="python, black holes, sourdough…"></div>
        <div>
          <label for="tr-source">Source</label>
          <select id="tr-source">
            <option value="mix">🌍 Everything credible (mix)</option>
            <option value="wikipedia">📕 Wikipedia</option>
            <option value="simple">🧒 Simple Wikipedia</option>
            <option value="wikibooks">📘 Wikibooks — how-to manuals</option>
            <option value="wikiversity">🎓 Wikiversity</option>
            <option value="wikivoyage">🗺️ Wikivoyage</option>
            <option value="wiktionary">📖 Wiktionary — definitions</option>
            <option value="arxiv">📄 arXiv — academic papers</option>
            <option value="openlibrary">📚 Open Library — books</option>
            <option value="howto">🛠️ Stack Exchange — expert how-to</option>
          </select>
        </div>
        <div>
          <label for="tr-size">How much</label>
          <select id="tr-size">
            <option value="20">Standard — ~20</option>
            <option value="100">Big — ~100</option>
            <option value="300">MEGA — ~300</option>
            <option value="1000">GIGA — ~1000</option>
          </select>
        </div>
        <button class="btn" id="tr-study">Study into this agent</button>
        <div class="note" id="tr-status"></div>
      </div>
    </div>
  </section>

  <!-- TOPICS -->
  <section id="tab-topics" class="tab">
    <div class="panel-pad">
      <h2>Chat scope — which knowledge to use</h2>
      <div id="topiclist"></div>
      <h2 style="margin-top:10px">Backup</h2>
      <div class="row">
        <button class="btn ghost" id="exportbtn">Export brain</button>
        <button class="btn ghost" id="importbtn">Import brain</button>
      </div>
      <input type="file" id="importfile" accept=".json" style="display:none">
      <p class="note">Export downloads everything (knowledge + memory) as a file. Import restores it.</p>
      <h2 style="margin-top:10px">☠️ Danger zone</h2>
      <button class="btn danger" id="wipebtn">Wipe Nova's memory</button>
      <p class="note">Erases everything — all facts, topics, XP, levels, achievements, and what Nova knows about you. It restarts as a newborn Hatchling. Consider Export first! This cannot be undone.</p>
    </div>
  </section>

  <!-- PERSONALITY -->
  <section id="tab-persona" class="tab">
    <div class="panel-pad">
      <h2>Pick a personality</h2>
      <div id="personalist"></div>
      <h2 style="margin-top:10px">Edit this personality</h2>
      <p class="note">One line per phrase — Nova picks randomly. Changes save instantly (and change its voice style too).</p>
      <div><label for="p-face">Face (emoji)</label><input id="p-face" type="text" maxlength="4"></div>
      <div><label for="p-color">Accent color</label><input id="p-color" type="color" style="width:100%; height:40px; background:var(--panel); border:1px solid var(--line); border-radius:10px;"></div>
      <div><label for="p-unknown">"I don't know" phrases</label><textarea id="p-unknown"></textarea></div>
      <div><label for="p-gotit">"Got it!" phrases</label><textarea id="p-gotit"></textarea></div>
      <div><label for="p-greet">Greeting phrases</label><textarea id="p-greet"></textarea></div>
      <button class="btn ghost" id="p-reset">Reset this personality to default</button>

      <h2 style="margin-top:10px">🧠 The Council — Nova's experts</h2>
      <p class="note">Nova is a team of 12 skill agents — Chat, Recall, Code, Write, Dream, Words, Scout, Teacher, Math, Sorter, Summarizer, and Analyst. A router reads each message and picks who does the job; the agent signs its reply in its own color and (with 🔊 on) speaks in its own voice. This is a mini "Mixture of Experts" — the real architecture inside big AIs. Tap an agent to rename it.</p>
      <div id="expertlist"></div>
    </div>
  </section>
</main>

<script>
"use strict";
/* =====================================================
   Nova v8 — a fully standalone learning AI.
   brain    = what it knows (facts)
   memory   = what it remembers about YOU
   dialogue = how it's learning to TALK, from you
===================================================== */

/* ---------- safe persistent storage ---------- */
const store = {
  ok:false,
  init(){ try{ localStorage.setItem("__t","1"); localStorage.removeItem("__t"); this.ok=true; }catch(e){ this.ok=false; } },
  get(k){ if(!this.ok) return null; try{ return JSON.parse(localStorage.getItem(k)); }catch(e){ return null; } },
  set(k,v){ if(!this.ok) return; try{ localStorage.setItem(k, JSON.stringify(v)); }catch(e){} }
};
store.init();

/* ---------- state ---------- */
let brain = store.get("nova_brain") || {
  general:{
    "hello":"Hey there! Teach me things and I'll get smarter.",
    "how are you":"Feeling bright! My brain grew since last time.",
    "what can you do":"Chat, learn anything, study Wikipedia, quiz you, imagine sentences, and learn to talk like you. Try the tabs!"
  }
};
let memory = Object.assign({
  name:null, sessions:0, factsTaught:0, lastTopic:"all",
  personality:"friendly", edits:{}, history:[],
  voice:false, xp:0, achieved:[],
  quizStats:{asked:0, correct:0, streak:0, best:0}
}, store.get("nova_memory") || {});

let scope = memory.lastTopic || "all";
let pendingTeach = null;
let awaitingName = false;
let lastSubject = null;      // conversation context ("it" = this)
let subjectHistory = [];     // 🧠 rolling memory of recent subjects, for
                              // follow-ups that reach further back than
                              // just the last thing discussed
let quizQ = null;

/* ---------- personalities ---------- */
const PRESETS = {
  friendly:{ name:"Friendly", face:"🙂", color:"#4FD8EB", desc:"Warm, upbeat, encouraging.", voice:{pitch:1, rate:1},
    greet:["Hey {n}! Ready to make me smarter?","Welcome back {n}! I missed learning with you.","Hi {n}! What are we exploring today?"],
    unknown:["Hmm, I don't know that yet — teach me? Just type the answer!","Ooh, a new one! What should I say? Type the answer to teach me.","I haven't learned that yet. Want to teach me? Type the answer!"],
    gotit:["Got it! My brain just grew. 🧠","Learned! Ask me again anytime.","Saved forever! Thanks, {n}."],
    chat:["Haha, nice! What else is on your mind, {n}?","I'm all ears! Want to quiz me or teach me something?","Good vibes! Ask me anything — or hit ✨ and I'll imagine something."] },
  sassy:{ name:"Sassy", face:"😏", color:"#FF7AB6", desc:"Confident with a little attitude.", voice:{pitch:1.25, rate:1.05},
    greet:["Oh look who's back. Missed me, {n}?","Finally, {n}. I was getting bored.","Hey {n}. Let's make me brilliant, obviously."],
    unknown:["Excuse me? Nobody taught me that. Type the answer, I'm waiting…","Not in my brain. Whose fault is that? Teach me — type the answer.","I know a lot, but not THAT. Fix it — type the answer."],
