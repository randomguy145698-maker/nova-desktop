{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Nova",
  "version": "1.0.0",
  "identifier": "com.carter.nova",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Nova \u2014 Your Learning AI",
        "width": 1000,
        "height": 800,
        "minWidth": 720,
        "minHeight": 560,
        "resizable": true,
        "center": true,
        "theme": "Dark",
        "backgroundColor": "#0E1420"
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data:; connect-src 'self' https://en.wikipedia.org https://simple.wikipedia.org https://en.wikibooks.org https://en.wikiversity.org https://en.wikivoyage.org https://en.wiktionary.org https://export.arxiv.org https://openlibrary.org https://api.stackexchange.com"
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis",
      "msi"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": false
      }
    },
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "PASTE_YOUR_GENERATED_PUBLIC_KEY_HERE",
      "endpoints": [
        "https://github.com/YOUR_GITHUB_USERNAME/YOUR_REPO_NAME/releases/latest/download/latest.json"
      ]
    }
  }
}